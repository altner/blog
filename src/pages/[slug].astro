---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  url: canonicalURL,
  author: {
    "@type": "Person",
    name: "Adrian Altner",
    url: Astro.site,
  },
  publisher: {
    "@type": "Person",
    name: "Adrian Altner",
    url: Astro.site,
  },
  inLanguage: "de",
};
---

<BaseLayout title={post.data.title} description={post.data.description} ogType="article">
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <main>
    <a class="back" href={import.meta.env.BASE_URL}>← Alle Beiträge</a>
    <h1>{post.data.title}</h1>
    <time datetime={post.data.date.toISOString()}>
      {post.data.date.toLocaleDateString("de-DE", { year: "numeric", month: "long", day: "numeric" })}
    </time>
    <div class="prose">
      <Content />
    </div>
  </main>
</BaseLayout>

<style>
  main {
    max-width: 65ch;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .back {
    display: inline-block;
    font-size: 0.875rem;
    color: #777;
    text-decoration: none;
    margin-bottom: 2.5rem;
    font-style: italic;
  }

  .back:hover {
    color: #1c1c1c;
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  time {
    display: block;
    font-size: 0.85rem;
    color: #777;
    font-style: italic;
    margin-bottom: 3rem;
  }

  .prose :global(h2) {
    font-size: 1.35rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(a) {
    text-decoration: underline;
  }
</style>
